local UIS = game:GetService("UserInputService")
local p = game.Players.LocalPlayer
local rs = game:GetService("RunService")

_G.YinYangActive = false

local function GetMyBase()
    local myBase = nil
    for _, mod in pairs(workspace:GetDescendants()) do
        if mod:IsA("Model") and not mod:IsDescendantOf(p.Character) then
            for _, txt in pairs(mod:GetDescendants()) do
                if (txt:IsA("TextLabel") or txt:IsA("TextObject")) and (txt.Text:find("ТВОЯ БАЗА") or txt.Text:find(p.Name)) then
                    myBase = mod
                    break
                end
            end
        end
        if myBase then break end
    end
    return myBase
end

local function ApplyYinYang()
    local b = GetMyBase()
    if b then
        _G.YinYangActive = not _G.YinYangActive
        for _, o in pairs(b:GetDescendants()) do
            if o:IsA("BasePart") then
                if o.Transparency > 0.8 or o.Size.Magnitude < 0.5 then continue end
                if _G.YinYangActive then
                    local n = o.Name:lower()
                    local s = o.Size
                    if n:find("window") or n:find("glass") then
                        o.Material, o.Color, o.Transparency = Enum.Material.Glass, Color3.new(0, 0, 0), 0.6
                    elseif n:find("frame") or n:find("border") or n:find("trim") or n:find("pillar") or (s.X < 2.2 and s.Z < 2.2) or (s.X < 2.2 and s.Y < 2.2) then
                        o.Material, o.Color = Enum.Material.SmoothPlastic, Color3.new(0, 0, 0)
                    elseif n:find("wall") or n:find("brick") or n:find("floor") or n:find("ceiling") or n:find("stair") or n:find("base") then
                        o.Material, o.Color = Enum.Material.Brick, Color3.new(1, 1, 1)
                        o.Transparency = 0
                    else
                        o.Material, o.Color = Enum.Material.SmoothPlastic, Color3.new(1, 1, 1)
                    end
                else
                    o.Material, o.Color, o.Transparency = Enum.Material.Plastic, Color3.new(1, 1, 1), 0
                end
            end
        end
    end
end

local function makeDraggable(f, h)
    local d, di, ds, sp
    h = h or f
    h.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then d = true ds = i.Position sp = f.Position i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then d = false end end) end end)
    h.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then di = i end end)
    UIS.InputChanged:Connect(function(i) if i == di and d then local delta = i.Position - ds f.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y) end end)
end

local function createMainInterface(gameType)
    if p.PlayerGui:FindFirstChild("PhoenixMenu") then p.PlayerGui.PhoenixMenu:Destroy() end
    local sg = Instance.new("ScreenGui", p.PlayerGui)
    sg.Name = "PhoenixMenu"
    sg.ResetOnSpawn = false

    local ob = Instance.new("TextButton", sg)
    ob.Size, ob.Position, ob.BackgroundColor3, ob.Text, ob.TextColor3 = UDim2.new(0, 55, 0, 55), UDim2.new(1, -70, 0.7, 0), Color3.fromRGB(20, 20, 20), "PH", Color3.new(1, 1, 1), 16
    ob.Font = Enum.Font.GothamBold
    Instance.new("UICorner", ob).CornerRadius = UDim.new(1, 0)
    local bs = Instance.new("UIStroke", ob)
    bs.Thickness = 3
    makeDraggable(ob)

    local m = Instance.new("Frame", sg)
    m.Size, m.Position, m.BackgroundColor3, m.Visible = UDim2.new(0, 300, 0, 300), UDim2.new(0.5, -150, 0.5, -150), Color3.fromRGB(15, 15, 15), false
    Instance.new("UICorner", m)
    local ms = Instance.new("UIStroke", m)
    ms.Thickness = 2
    makeDraggable(m)

    local cont = Instance.new("Frame", m)
    cont.Size, cont.Position, cont.BackgroundTransparency = UDim2.new(1, -20, 1, -20), UDim2.new(0, 10, 0, 10), 1
    Instance.new("UIListLayout", cont).Padding = UDim.new(0, 10)

    local function cB(txt, func)
        local b = Instance.new("TextButton", cont)
        b.Size, b.Text, b.BackgroundColor3, b.TextColor3, b.Font = UDim2.new(1, 0, 0, 45), txt, Color3.fromRGB(30,30,30), Color3.new(1,1,1), Enum.Font.GothamBold
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(func)
    end

    if gameType == "Brainrot" then
        cB("YIN YANG BASE", function() ApplyYinYang() end)
        cB("WALKSPEED", function() p.Character.Humanoid.WalkSpeed = 100 end)
    elseif gameType == "DeadRails" then
        cB("DEAD RAILS HUB", function() print("Dead Rails logic here") end)
        cB("ESP PLAYERS", function() print("ESP Active") end)
    end

    task.spawn(function() while task.wait() do local clr = Color3.fromHSV(tick() % 5 / 5, 0.8, 1) bs.Color, ms.Color, ob.TextColor3 = clr, clr, clr end end)
    ob.MouseButton1Click:Connect(function() m.Visible = not m.Visible end)
end

