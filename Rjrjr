local function createMenu(gN)
    sG:Destroy()
    local sg = Instance.new("ScreenGui", p.PlayerGui)
    sg.Name = "PhoenixHub"
    sg.ResetOnSpawn = false
    local ob = Instance.new("TextButton", sg)
    ob.Size, ob.Position, ob.BackgroundColor3, ob.Text, ob.TextColor3 = UDim2.new(0, 55, 0, 55), UDim2.new(1, -70, 0.7, 0), Color3.fromRGB(20, 20, 20), "PH", Color3.new(1,1,1)
    Instance.new("UICorner", ob).CornerRadius = UDim.new(1,0)
    local bs = Instance.new("UIStroke", ob)
    bs.Thickness = 3
    makeDraggable(ob)

    local m = Instance.new("Frame", sg)
    m.Size, m.Position, m.BackgroundColor3, m.Visible = UDim2.new(0, 400, 0, 350), UDim2.new(0.5, -200, 0.5, -175), Color3.fromRGB(15, 15, 15), false
    Instance.new("UICorner", m)
    local ms = Instance.new("UIStroke", m)
    ms.Thickness = 2
    makeDraggable(m)

    local sb = Instance.new("Frame", m)
    sb.Size, sb.BackgroundColor3 = UDim2.new(0, 100, 1, 0), Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", sb)
    local c = Instance.new("Frame", m)
    c.Position, c.Size, c.BackgroundTransparency = UDim2.new(0, 110, 0, 10), UDim2.new(1, -120, 1, -20), 1
    local mp = Instance.new("Frame", c)
    mp.Size, mp.Visible, mp.BackgroundTransparency = UDim2.new(1, 0, 1, 0), true, 1
    Instance.new("UIListLayout", mp).Padding = UDim.new(0, 10)
    local bp = Instance.new("Frame", c)
    bp.Size, bp.Visible, bp.BackgroundTransparency = UDim2.new(1, 0, 1, 0), false, 1
    Instance.new("UIListLayout", bp).Padding = UDim.new(0, 10)

    local function cT(n, y, pge)
        local b = Instance.new("TextButton", sb)
        b.Size, b.Position, b.Text, b.BackgroundColor3, b.TextColor3, b.Font = UDim2.new(0.9, 0, 0, 40), UDim2.new(0.05, 0, 0, y), n, Color3.fromRGB(30, 30, 30), Color3.new(1,1,1), Enum.Font.GothamBold
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function() mp.Visible, bp.Visible = false, false pge.Visible = true end)
    end

    cT("Main", 10, mp)
    if gN == "Brainrot" then cT("Base", 60, bp) end

    _G.N = false
    rs.Stepped:Connect(function() if _G.N and p.Character then for _, v in pairs(p.Character:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end end end)

    local nb = Instance.new("TextButton", mp)
    nb.Size, nb.BackgroundColor3, nb.Text, nb.TextColor3 = UDim2.new(1, 0, 0, 40), Color3.fromRGB(30, 30, 30), "NOCLIP: OFF (N)", Color3.new(1,1,1)
    Instance.new("UICorner", nb)
    nb.MouseButton1Click:Connect(function() _G.N = not _G.N nb.Text = "NOCLIP: " .. (_G.N and "ON" or "OFF") end)

    UIS.InputBegan:Connect(function(i, g) if not g and i.KeyCode == Enum.KeyCode.N then _G.N = not _G.N nb.Text = "NOCLIP: " .. (_G.N and "ON" or "OFF") end end)

    if gN == "Brainrot" then
        local rbb = Instance.new("TextButton", bp)
        rbb.Size, rbb.Text, rbb.BackgroundColor3, rbb.TextColor3 = UDim2.new(1,0,0,40), "RAINBOW BASE", Color3.fromRGB(40,40,40), Color3.new(1,1,1)
        Instance.new("UICorner", rbb)
        rbb.MouseButton1Click:Connect(function() loadstring(game:HttpGet('https://sirius.menu'))() end)

        local yb = Instance.new("TextButton", bp)
        yb.Size, yb.Text, yb.BackgroundColor3, yb.TextColor3 = UDim2.new(1,0,0,40), "YIN YANG BASE", Color3.fromRGB(20,20,20), Color3.new(1,1,1)
        Instance.new("UICorner", yb)
        local ys = Instance.new("UIStroke", yb)
        ys.Thickness, ys.Color = 2, Color3.new(1,1,1)
        yb.MouseButton1Click:Connect(function() ColorMyBase() yb.Text = "COLORED!" end)
    end

    task.spawn(function() while task.wait() do local clr = Color3.fromHSV(tick() % 5 / 5, 0.8, 1) bs.Color, ms.Color, ob.TextColor3 = clr, clr, clr end end)
    ob.MouseButton1Click:Connect(function() m.Visible = not m.Visible end)
    local si = Instance.new("TextBox", mp)
    si.Size, si.PlaceholderText, si.BackgroundColor3, si.TextColor3 = UDim2.new(1,0,0,40), "WALKSPEED (1-400)", Color3.fromRGB(30,30,30), Color3.new(1,1,1)
    Instance.new("UICorner", si)
    si.FocusLost:Connect(function() if tonumber(si.Text) and p.Character.Humanoid then p.Character.Humanoid.WalkSpeed = math.clamp(tonumber(si.Text), 1, 400) end end)
end

