local container = Instance.new("Frame", main)
container.Position, container.Size, container.BackgroundTransparency = UDim2.new(0, 10, 0, 10), UDim2.new(1, -20, 1, -20), 1
local layout = Instance.new("UIListLayout", container)
layout.Padding, layout.HorizontalAlignment = UDim.new(0, 10), Enum.HorizontalAlignment.Center

openBtn.MouseButton1Click:Connect(function() main.Visible = not main.Visible end)

local function getMyBase()
    for _, mod in pairs(workspace:GetDescendants()) do
        if mod:IsA("Model") and not mod:IsDescendantOf(p.Character) then
            for _, o in pairs(mod:GetDescendants()) do
                if (o:IsA("TextLabel") or o:IsA("TextBox") or o:IsA("TextObject")) and (o.Text:find("YOUR BASE") or o.Text:find("ТВОЯ БАЗА") or o.Text:find(p.Name)) then
                    return mod
                end
            end
        end
    end
    return nil
end

local baseBtn = Instance.new("TextButton", container)
baseBtn.Size, baseBtn.BackgroundColor3 = UDim2.new(1, 0, 0, 45), Color3.fromRGB(25, 25, 25)
baseBtn.Text, baseBtn.TextColor3, baseBtn.Font = "RAINBOW BASE: OFF", Color3.new(1, 1, 1), Enum.Font.GothamBold
Instance.new("UICorner", baseBtn)

_G.BaseRainbow = false
baseBtn.MouseButton1Click:Connect(function()
    _G.BaseRainbow = not _G.BaseRainbow
    if _G.BaseRainbow then _G.YinYang = false end
    baseBtn.Text = "RAINBOW BASE: " .. (_G.BaseRainbow and "ON" or "OFF")
    task.spawn(function()
        local b = getMyBase()
        if b then
            while _G.BaseRainbow do
                local clr = Color3.fromHSV(tick() % 8 / 8, 0.7, 1)
                for _, o in pairs(b:GetDescendants()) do
                    if o:IsA("BasePart") then o.Color, o.Material = clr, Enum.Material.Neon end
                end
                rs.RenderStepped:Wait()
            end
        end
    end)
end)

local yinBtn = Instance.new("TextButton", container)
yinBtn.Size, yinBtn.BackgroundColor3 = UDim2.new(1, 0, 0, 45), Color3.fromRGB(25, 25, 25)
yinBtn.Text, yinBtn.TextColor3, yinBtn.Font = "YIN YANG BASE: OFF", Color3.new(1, 1, 1), Enum.Font.GothamBold
Instance.new("UICorner", yinBtn)

_G.YinYang = false
yinBtn.MouseButton1Click:Connect(function()
    _G.YinYang = not _G.YinYang
    if _G.YinYang then _G.BaseRainbow = false end
    yinBtn.Text = "YIN YANG BASE: " .. (_G.YinYang and "ON" or "OFF")
    task.spawn(function()
        local b = getMyBase()
        if b then
            while _G.YinYang do
                local t = tick() * 3
                for _, o in pairs(b:GetDescendants()) do
                    if o:IsA("BasePart") then
                        local noise = math.sin(t + (o.Position.X * 0.2) + (o.Position.Z * 0.2))
                        local val = noise > 0 and 1 or 0
                        o.Color = Color3.new(val, val, val)
                        o.Material = Enum.Material.Neon
                        o.Transparency = 0.2
                    end
                end
                rs.RenderStepped:Wait()
            end
            for _, o in pairs(b:GetDescendants()) do
                if o:IsA("BasePart") then o.Material, o.Transparency = Enum.Material.Plastic, 0 end
            end
        end
    end)
end)

local speedInput = Instance.new("TextBox", container)
speedInput.Size, speedInput.BackgroundColor3 = UDim2.new(1, 0, 0, 45), Color3.fromRGB(25, 25, 25)
speedInput.PlaceholderText = "SPEED (0-400)"
speedInput.Text, speedInput.TextColor3, speedInput.Font = "", Color3.new(1, 1, 1), Enum.Font.GothamBold
Instance.new("UICorner", speedInput)

speedInput.FocusLost:Connect(function(enter)
    if enter and tonumber(speedInput.Text) then
        local s = math.clamp(tonumber(speedInput.Text), 0, 400)
        if p.Character and p.Character:FindFirstChild("Humanoid") then
            p.Character.Humanoid.WalkSpeed = s
            speedInput.Text = "SPEED: " .. s
        end
    end
end)

task.spawn(function()
    while task.wait(1) do
        for _, v in pairs(workspace:GetDescendants()) do
            if (v:IsA("BoxHandleAdornment") or v:IsA("SelectionBox")) and v.Parent and v.Parent:IsA("Model") and v.Parent ~= p.Character then
                v:Destroy()
            end
        end
    end
end)
